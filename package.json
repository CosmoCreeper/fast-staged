{
  "name": "fast-staged",
  "version": "1.0.0",
  "description": "A drop-in replacement for lint-staged, optimized for speed",
  "keywords": [
    "fast",
    "git",
    "hooks",
    "lint",
    "lint-staged",
    "staged"
  ],
  "license": "MIT",
  "bin": {
    "fast-staged": "./bin/fast-staged.js",
    "lint-staged": "./bin/fast-staged.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./bin": "./bin/fast-staged.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "node build.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0"
  },
  "lint-staged": {
    "*": [
      "node --check",
      "oxfmt --check"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "name": "fast-staged",
  "version": "1.0.1",
  "description": "A drop-in replacement for lint-staged, optimized for speed",
  "keywords": [
    "fast",
    "git",
    "hooks",
    "lint",
    "lint-staged",
    "staged"
  ],
  "license": "MIT",
  "author": "CosmoCreeper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmoCreeper/fast-staged"
  },
  "bin": {
    "fast-staged": "./dist/cli.js",
    "lint-staged": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "node build.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.49.0"
  },
  "lint-staged": {
    "lean": true,
    "*.{js,mjs}": [
      "node --check"
    ],
    "*": [
      "oxfmt --check"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
